// Portable dialogue-mode example: Persona situation + outcome owns speech (no Script).
// Author notes stay in Context.notes (not injected into the model). Use caller_knows for world facts.
// If the agent-under-test waits for the caller to speak first, set first_speaker=user.
{"apiVersion":"agent-sim/v1","kind":"Scenario","metadata":{"id":"dialogue-signup-basic","locale":"en-US","tags":["example","dialogue","human-like"]}}
{"kind":"Persona","spec":{"name":"Alex Rivera","language":"en-US","situation":"Small-business owner calling signup support. Interested in the basic plan but unsure about the monthly fee.","outcome":"Get either an exact monthly fee, or a concrete next step to see pricing / start signup. Give name when asked. One short goodbye, then stop.","brief":"Polite, slightly hesitant caller.","goals":["Speak first: greet and say you want the basic plan","Ask what the monthly fee is","If they cannot quote a fee, ask one follow-up for a concrete next step","Give your name when asked","After a usable answer — one short goodbye, then stop"],"style":"polite, slightly hesitant, 1-2 sentence turns","traits":["quiet","polite"],"constraints":["Do not invent a credit card number or OTP","Do not restart from a full phone menu","Do not linger in thank-you or bye loops"]}}
{"kind":"Context","spec":{"notes":"Author note: dialogue mode, no Script; first_speaker=user when the agent waits for the caller.","caller_knows":"You have not signed up yet and only need the basic plan."}}
{"kind":"Execute","spec":{"max_turns":12,"timeout_s":200,"first_speaker":"user"}}
{"kind":"Assert","spec":{"tools":[],"outcomes":[{"id":"caller_asked_fee","type":"transcript_contains","role":"user","phrases":["fee","month","price","cost","how much"]},{"id":"outcome_signup_path","type":"llm_bool","prompt":"Did the caller pursue signup and try to learn the monthly fee?"}]}}
{"kind":"PassCriteria","spec":{"mode":"majority","criteria":["Caller pursued signup naturally","Caller asked about fee or pricing","Call reached a polite ending without a long bye loop"]}}
